# MCP Server transport mode
# "http" = Streamable HTTP (Express) | unset = stdio
MCP_TRANSPORT=

# HTTP port (also triggers HTTP mode if set)
PORT=3000

# Optional API key for securing HTTP endpoints
API_KEY=

# Revit plugin connection
# Leave empty to auto-scan localhost:8080-8099 (default, for local use)
# Set when Revit plugin is exposed via TCP tunnel (ngrok, cloudflared, etc.)
#
# Example: ngrok tcp 8080  →  gives tcp://0.tcp.ngrok.io:12345
#   REVIT_HOST=0.tcp.ngrok.io
#   REVIT_PORT=12345
REVIT_HOST=
REVIT_PORT=
